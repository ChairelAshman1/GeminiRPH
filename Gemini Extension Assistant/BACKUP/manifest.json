{
  "manifest_version": 3,
  "name": "Gemini RPH Generator (Side Panel)",
  "version": "2.8.0",
  "description": "Jana RPH automatik di Side Panel dengan Carian DSKP Pintar.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "sidePanel",
    "contextMenus",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://*/*",
    "https://generativelanguage.googleapis.com/*",
    "https://docs.google.com/spreadsheets/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/spreadsheets/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Buka RPH Generator"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "side_panel": {
    "default_path": "geminiRPH.html"
  }
}